set term pngcairo size 800,800 enhanced font 'Arial,28'
set output "band-gr.PNG"
set border lt 1 lw 3 lc rgb 'black'
set key outside center bottom horizontal
set zeroaxis

# Pastikan ytics hanya di kiri dan tidak ada mirror
set ytics 0.2 out nomirror 

# Pastikan x-tics tidak memunculkan tick di atas
set xtics out nomirror 

# Sangat penting: Pastikan y2tics sepenuhnya tidak aktif jika pernah diatur sebelumnya
unset y2tics
unset my2tics

set ytics font "Arial, 35"
set xtics font "Arial, 30"

set xrange [-6: 6]
set yrange [0:0.6]

set ylabel "DOS (States/eV)" font ("Arial, 40")
set xlabel "Energy (eV)" font ("Arial, 40")

 
set xzeroaxis lt 0 lw 2 lc rgb 'black'

# Pastikan plot menggunakan sumbu y1 (default), bukan y2
plot "gr.txt" w l lw 3 lc rgb '#694B2D' ti " ",

unset key